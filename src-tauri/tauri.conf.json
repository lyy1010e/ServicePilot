{
  "$schema": "./gen/schemas/desktop-schema.json",
  "productName": "ServicePilot",
  "version": "1.0.11",
  "identifier": "com.servicepilot.desktop",
  "build": {
    "beforeDevCommand": "npm run dev:renderer",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build:renderer",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "ServicePilot",
        "width": 1320,
        "height": 860,
        "minWidth": 1024,
        "minHeight": 680,
        "resizable": true,
        "decorations": false,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "capabilities": [
        "default"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ],
    "targets": "all",
    "windows": {
      "wix": {
        "language": "zh-CN"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDUxNjFDRjkyMjMyNDMwM0QKUldROU1DUWprczloVVNJNGhXRW9PT2UwK3pwZDE5emhPelpwbXV5VDVxdTJWeTlrdEJrS0ZyeGcK",
      "endpoints": [
        "https://github.com/lyy1010e/ServicePilot/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "quiet"
      }
    }
  }
}
